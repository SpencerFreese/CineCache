<!DOCTYPE html>
<html lang="en">
{{> fragments/html_header}}

<body>

    <div class="container center-align narrow">
        <h1 class="login-title">Login</h1>
        {{> fragments/error_message}}
        <form method="post" action="/login">
            <input name="username" class="short-input full" type="text" placeholder="Username">
            <input name="password" class="short-input full" type="password" placeholder="Password">
            <div class="login-buttons">
                <button type="submit" class="action-button">Login</button>
                <a class="link" href="/register">Register</a>
            </div>
        </form>
    </div>

</body>

</html>